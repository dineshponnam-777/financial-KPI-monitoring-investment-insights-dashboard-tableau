      <aliases enabled='yes' />
      <column caption='Profit Margin KPI' datatype='real' name='[Calculation_0953008821690368]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Revenue])*100' />
      </column>
      <column caption='ROI KPI' datatype='real' name='[Calculation_0953008821841921]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Investment Amount])*100' />
      </column>
      <column caption='Budget Variance KPI' datatype='real' name='[Calculation_0953008821989378]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Actual Revenue]) - SUM([Budgeted Revenue]))&#13;&#10;/&#13;&#10;SUM([Budgeted Revenue])' />
      </column>
